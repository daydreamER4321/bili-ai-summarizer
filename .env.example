# LLM API 配置（必填）
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# 输出目录（默认: ./output）
OUTPUT_DIR=./output

# B站Cookie（CC字幕需要登录态）
# 方式1：自动从浏览器读取（需安装 pip install browser-cookie3）
# 方式2：手动设置环境变量
BILIBILI_SESSDATA=your-sessdata-here

# ASR语音转写配置（无CC字幕时自动启用）
# ASR_MODEL=base
# ASR_DEVICE=auto
